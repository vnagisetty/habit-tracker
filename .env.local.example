# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in every value before running the app.
# .env.local is gitignored; this file is safe to commit (no real secrets here).
# ──────────────────────────────────────────────────────────────────────────────

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID (Web application).
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=<your-google-oauth-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-google-oauth-client-secret>

# NextAuth
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=<random-32-byte-base64-string>
NEXTAUTH_URL=http://localhost:3000

# Google Sheets — the spreadsheet that stores habits and logs
# The sheet must have two tabs: "habits" and "logs" (see README for column layout)
GOOGLE_SHEETS_ID=<your-google-spreadsheet-id>

# Google Service Account — used server-side to read/write the sheet
# Grant the service account "Editor" access to the spreadsheet
GOOGLE_SERVICE_ACCOUNT_EMAIL=<service-account-name>@<project-id>.iam.gserviceaccount.com

# Paste the private key exactly as it appears in the downloaded JSON key file.
# Keep the surrounding quotes; literal \n sequences represent newlines.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<key-material>\n-----END PRIVATE KEY-----\n"
